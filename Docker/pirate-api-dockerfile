FROM python:3.14.6-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PGEOCODE_DATA_DIR=/app/pgeocode_data

ARG PGEOCODE_COUNTRIES="ad ar as at au ax az bd be bg bm br by ca ch cl co cr cy cz de dk do dz ee es fi fm fo fr gb gf gg gl gp gt gu hr ht hu ie im in is it je jp kr li lk lt lu lv mc md mh mk mp mq mt mw mx my nc nl no nz pe ph pk pl pm pr pt pw re ro rs ru se sg si sj sk sm th tr ua us uy va vi wf yt za"

RUN apt update && \
    apt -y install build-essential \
                    libffi-dev \
                    unzip \
                    rsync \
					git
                            
# Set the working directory inside the container
WORKDIR /app

# Install deps first for better build caching
COPY Docker/requirements-api.txt /app/
RUN pip install --no-cache-dir -r /app/requirements-api.txt

# Copy the run scripts from the API directory (relative to the build context)
COPY API /app/API
COPY MCP /app/MCP

# Preload pgeocode's GeoNames postal-code data so City,Country geocoding works
# without first-request network access. pgeocode stores downloaded country data
# in PGEOCODE_DATA_DIR.
RUN mkdir -p "$PGEOCODE_DATA_DIR" && \
    PGEOCODE_COUNTRIES="$PGEOCODE_COUNTRIES" python - <<'PY'
import os

import pgeocode

countries = os.environ["PGEOCODE_COUNTRIES"].split()
for country in countries:
    pgeocode.Nominatim(country)
print(f"Cached pgeocode data for {len(countries)} countries")
PY

ENTRYPOINT ["uvicorn"]

# Set the default command
CMD ["API.responseLocal:app", "--host", "0.0.0.0"]
